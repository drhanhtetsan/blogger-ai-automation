# Core API Keys
GEMINI_API_KEY=
PEXELS_API_KEY=

# WordPress Auth (required when DRY_RUN=false)
WORDPRESS_URL=https://your-site.com
WORDPRESS_USERNAME=automation-bot
WORDPRESS_APP_PASSWORD=xxxx xxxx xxxx xxxx xxxx xxxx

# Publishing Behavior
WORDPRESS_DEFAULT_CATEGORIES=Automation
WORDPRESS_POST_STATUS=draft
DRY_RUN=true

# Queue + runtime
TRACKING_CSV_PATH=config/topics.csv
COMMENTS_CSV_PATH=config/comments.csv
BATCH_SIZE=3
MAX_RETRIES=3
REQUEST_TIMEOUT=30

# Optional alerts
SLACK_WEBHOOK_URL=

# Optional header
USER_AGENT=wordpress-ai-automation/1.0
